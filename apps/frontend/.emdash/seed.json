{
  "$schema": "https://emdashcms.com/seed.schema.json",
  "version": "1",
  "meta": {
    "name": "Majelis Nur Muhammad",
    "description": "Skema konten situs Majelis Nur Muhammad"
  },
  "defaultLocale": "id",
  "collections": [
    {
      "slug": "articles",
      "label": "Artikel",
      "labelSingular": "Artikel",
      "supports": [
        "drafts"
      ],
      "fields": [
        {
          "slug": "title",
          "type": "string",
          "label": "Judul",
          "required": true
        },
        {
          "slug": "category",
          "type": "select",
          "label": "Kategori",
          "required": true,
          "validation": {
            "options": [
              "tafsir",
              "hadits",
              "fiqih",
              "akhlak",
              "umum"
            ]
          }
        },
        {
          "slug": "excerpt",
          "type": "text",
          "label": "Ringkasan"
        },
        {
          "slug": "cover_image",
          "type": "image",
          "label": "Gambar Sampul"
        },
        {
          "slug": "content",
          "type": "portableText",
          "label": "Isi",
          "required": true
        },
        {
          "slug": "tags",
          "type": "multiSelect",
          "label": "Tag"
        },
        {
          "slug": "author",
          "type": "string",
          "label": "Penulis"
        },
        {
          "slug": "published_date",
          "type": "datetime",
          "label": "Tanggal Terbit"
        }
      ]
    },
    {
      "slug": "schedules",
      "label": "Jadwal Pengajian",
      "labelSingular": "Jadwal",
      "fields": [
        {
          "slug": "title",
          "type": "string",
          "label": "Nama Kegiatan",
          "required": true
        },
        {
          "slug": "day",
          "type": "select",
          "label": "Hari",
          "required": true,
          "validation": {
            "options": [
              "ahad",
              "senin",
              "selasa",
              "rabu",
              "kamis",
              "jumat",
              "sabtu"
            ]
          }
        },
        {
          "slug": "time_start",
          "type": "string",
          "label": "Waktu Mulai"
        },
        {
          "slug": "time_end",
          "type": "string",
          "label": "Waktu Selesai"
        },
        {
          "slug": "ustadz",
          "type": "string",
          "label": "Pemateri / Ustadz"
        },
        {
          "slug": "kitab",
          "type": "string",
          "label": "Kitab / Materi"
        },
        {
          "slug": "location",
          "type": "string",
          "label": "Lokasi"
        },
        {
          "slug": "description",
          "type": "text",
          "label": "Keterangan"
        },
        {
          "slug": "recurring",
          "type": "boolean",
          "label": "Rutin Mingguan"
        },
        {
          "slug": "order",
          "type": "integer",
          "label": "Urutan"
        }
      ]
    },
    {
      "slug": "announcements",
      "label": "Pengumuman",
      "labelSingular": "Pengumuman",
      "supports": [
        "drafts"
      ],
      "fields": [
        {
          "slug": "title",
          "type": "string",
          "label": "Judul",
          "required": true
        },
        {
          "slug": "body",
          "type": "portableText",
          "label": "Isi Pengumuman",
          "required": true
        },
        {
          "slug": "date",
          "type": "datetime",
          "label": "Tanggal"
        },
        {
          "slug": "pinned",
          "type": "boolean",
          "label": "Sematkan (tampil di beranda)"
        },
        {
          "slug": "expires_at",
          "type": "datetime",
          "label": "Berlaku Sampai"
        }
      ]
    },
    {
      "slug": "team",
      "label": "Pengurus",
