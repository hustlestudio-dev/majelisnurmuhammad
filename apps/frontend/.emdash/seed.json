        {
          "slug": "name",
          "type": "string",
          "label": "Nama",
          "required": true
        },
        {
          "slug": "role",
          "type": "string",
          "label": "Jabatan",
          "required": true
        },
        {
          "slug": "photo",
          "type": "image",
          "label": "Foto"
        },
        {
          "slug": "bio",
          "type": "text",
          "label": "Biografi Singkat"
        },
        {
          "slug": "order",
          "type": "integer",
          "label": "Urutan"
        }
      ]
    },
    {
