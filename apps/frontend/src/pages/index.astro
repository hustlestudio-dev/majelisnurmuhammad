---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Hero from '@/components/Hero.astro'
import SectionHeading from '@/components/SectionHeading.astro'
import Divider from '@/components/Divider.astro'
import Button from '@/components/Button.astro'
import AnnouncementCard from '@/components/AnnouncementCard.astro'
import ScheduleCard from '@/components/ScheduleCard.astro'
import ArticleCard from '@/components/ArticleCard.astro'
import {
  getSiteSettings,
  getAnnouncements,
  getSchedules,
  getLatestArticles,
} from '@/lib/content'
import { DAY_ORDER } from '@/lib/constants'

const [settings, announcements, schedules, articles] = await Promise.all([
  getSiteSettings(),
  getAnnouncements(true),
  getSchedules(),
  getLatestArticles(3),
])

const weekSchedules = [...schedules]
  .sort((a, b) => DAY_ORDER.indexOf(a.day) - DAY_ORDER.indexOf(b.day))
  .slice(0, 4)

const social = settings.social ?? {}
const videoChannels = [
  {
    href: social.youtube,
    name: 'YouTube',
    desc: 'Rekaman kajian & ceramah terbaru.',
    icon: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
  },
  {
    href: social.tiktok,
    name: 'TikTok',
    desc: 'Potongan nasihat singkat & dakwah harian.',
    icon: 'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z',
  },
].filter((c) => c.href)
---
<BaseLayout settings={settings}>
  <Hero settings={settings} />

  {
    announcements.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
        <SectionHeading
          title="Pengumuman Terkini"
          subtitle="Informasi penting seputar kegiatan dan agenda majelis."
        />
        <div class="mt-10 grid gap-5 sm:grid-cols-2">
          {announcements.slice(0, 4).map((a) => (
            <AnnouncementCard announcement={a} />
          ))}
        </div>
      </section>
    )
  }

  <section class="bg-secondary/40">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <SectionHeading
        title="Jadwal Pengajian"
        subtitle="Hadirilah majelis ilmu bersama. Terbuka untuk umum."
      />
      {
        weekSchedules.length > 0 ? (
          <div class="mt-10 grid gap-5 md:grid-cols-2">
            {weekSchedules.map((s) => (
              <ScheduleCard schedule={s} />
            ))}
          </div>
        ) : (
          <p class="mt-10 text-center text-muted-foreground">Belum ada jadwal.</p>
        )
      }
      <div class="mt-10 flex justify-center">
        <Button href="/jadwal" variant="outline">Lihat Semua Jadwal</Button>
      </div>
    </div>
  </section>

  {
    articles.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
        <SectionHeading
          title="Artikel Terbaru"
          subtitle="Bacaan keislaman: tafsir, hadits, fiqih, dan akhlak."
        />
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
        <div class="mt-10 flex justify-center">
          <Button href="/artikel" variant="outline">Jelajahi Artikel</Button>
        </div>
      </section>
    )
  }

  {
    videoChannels.length > 0 && (
      <section class="bg-secondary/40">
        <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
          <SectionHeading
            title="Kanal Dakwah Kami"
            subtitle="Ikuti kajian dan dakwah majelis di media sosial."
          />
          <div class="mx-auto mt-10 grid max-w-3xl gap-4 sm:grid-cols-2">
            {videoChannels.map((c) => (
              <a
                href={c.href!}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-4 rounded-2xl border border-border bg-card px-5 py-4 transition-colors hover:border-primary/40 hover:bg-accent/40"
              >
                <span class="flex size-11 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-foreground">
                  <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={c.icon} />
                  </svg>
                </span>
                <span class="min-w-0 flex-1">
                  <span class="block font-display font-semibold">{c.name}</span>
                  <span class="block text-sm text-muted-foreground">{c.desc}</span>
                </span>
                <span class="text-primary transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary via-primary to-primary-accent px-6 py-14 text-center text-primary-foreground sm:px-12">
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.07]"
        style="background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0); background-size: 24px 24px;"
        aria-hidden="true"
      />
      <div class="relative mx-auto max-w-2xl">
        <Divider class="mb-6" />
        <h2 class="font-display text-3xl font-bold text-balance sm:text-4xl">
          Mari Bergabung dalam Majelis Ilmu
        </h2>
        <p class="mt-4 text-pretty text-primary-foreground/85">
          Bersama menuntut ilmu, memperkuat ukhuwah, dan menyebarkan rahmat bagi sesama.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <Button href="/tentang" variant="gold" size="lg">Tentang Kami</Button>
          <Button
            href="/jadwal"
            size="lg"
            class="border border-white/30 bg-white/10 text-white hover:bg-white/20"
          >
            Ikuti Pengajian
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
