---
export const prerender = false

import BaseLayout from '@/layouts/BaseLayout.astro'
import Button from '@/components/Button.astro'
import Divider from '@/components/Divider.astro'
import StarOrnament from '@/components/StarOrnament.astro'
import { getAnnouncementById } from '@/lib/content'
import { renderRichText, richTextToPlain } from '@/lib/richtext'
import { formatDateID } from '@/lib/constants'

const { id } = Astro.params
const announcement = id ? await getAnnouncementById(id) : null

if (!announcement) {
  return new Response(null, {
    status: 404,
    statusText: 'Pengumuman tidak ditemukan',
  })
}

const body = renderRichText(announcement.body)
const description = richTextToPlain(announcement.body, 160)
---
<BaseLayout title={announcement.title} description={description}>
  <article>
    <header class="islamic-grid relative overflow-hidden border-b border-border/60">
      <StarOrnament class="absolute -top-8 -right-8 size-40 opacity-[0.07]" />
      <StarOrnament class="absolute -bottom-10 -left-10 size-44 opacity-[0.07]" />
      <div class="relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
        <h1 class="font-display text-3xl font-extrabold text-balance sm:text-4xl md:text-5xl">
          <span class="text-gradient-emerald">{announcement.title}</span>
        </h1>
        {
          announcement.date && (
            <p class="mt-5 text-sm text-muted-foreground">
              {formatDateID(announcement.date)}
            </p>
          )
        }
        <Divider class="mt-7" />
      </div>
    </header>

    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
      <div class="article-prose" set:html={body}></div>

      <div class="mt-12 flex justify-center">
        <Button href="/" variant="outline">← Kembali ke Beranda</Button>
      </div>
    </div>
  </article>
</BaseLayout>
