---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHeader from '@/components/PageHeader.astro'
import ScheduleCard from '@/components/ScheduleCard.astro'
import { getSchedules } from '@/lib/content'
import { DAY_ORDER, DAY_LABELS } from '@/lib/constants'

const schedules = await getSchedules()

const byDay = DAY_ORDER.map((day) => ({
  day,
  label: DAY_LABELS[day],
  items: schedules
    .filter((s) => s.day === day)
    .sort((a, b) => (a.order ?? 0) - (b.order ?? 0)),
})).filter((group) => group.items.length > 0)
---
<BaseLayout
  title="Jadwal Pengajian"
  description="Jadwal pengajian dan kajian rutin Majelis Nur Muhammad — terbuka untuk umum."
>
  <PageHeader
    title="Jadwal Pengajian"
    subtitle="Agenda kajian rutin majelis. Mari hadir dan raih keberkahan ilmu."
  />

  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    {
      byDay.length > 0 ? (
        <div class="space-y-12">
          {byDay.map((group) => (
            <div>
              <h2 class="mb-5 flex items-center gap-3 text-base font-normal">
                <span class="inline-flex items-center rounded-full bg-primary px-4 py-1.5 font-display text-sm font-bold text-primary-foreground">
                  {group.label}
                </span>
                <span class="h-px flex-1 bg-border"></span>
              </h2>
              <div class="grid gap-5 md:grid-cols-2">
                {group.items.map((s) => (
                  <ScheduleCard schedule={s} />
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-center text-muted-foreground">Belum ada jadwal yang tersedia.</p>
      )
    }
  </div>
</BaseLayout>
