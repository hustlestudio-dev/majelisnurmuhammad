---
import '@fontsource-variable/plus-jakarta-sans'
import '@fontsource/poppins/500.css'
import '@fontsource/poppins/600.css'
import '@fontsource/poppins/700.css'
import '@fontsource/amiri/400.css'
import '@fontsource/amiri/700.css'
import '@/styles/starwind.css'

import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import { SEO } from 'astro-seo'
import { getSiteSettings, mediaUrl } from '@/lib/content'
import type { SiteSettings } from '@/lib/types'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  settings?: SiteSettings
}

const { title, description, ogImage, settings: settingsProp } = Astro.props
const settings = settingsProp ?? (await getSiteSettings())
const siteName = settings.siteName ?? 'Majelis Nur Muhammad'
const tagline = settings.tagline ?? 'Pondok Pesantren Nur Muhammad Al-Hasany Banjaran'
const pageTitle = title ? `${title} · ${siteName}` : `${siteName} — ${tagline}`
const desc =
  description ??
  'Majelis Nur Muhammad — pusat kajian Islam Ahlussunnah wal Jama\'ah. Informasi jadwal pengajian, artikel keislaman, dan kegiatan dakwah. Dukung dakwah kami melalui donasi untuk keberlangsungan majelis.'
const ogImg = ogImage ?? mediaUrl(settings.logo) ?? '/logo.jpeg'
const ogImgAbsolute = new URL(ogImg, Astro.site ?? Astro.url).href
const ogImageMeta = {
  url: ogImgAbsolute,
  width: settings.logo?.width ?? 1080,
  height: settings.logo?.height ?? 1080,
  type: ogImg.endsWith('.png') ? 'image/png' : 'image/jpeg',
  alt: siteName,
}
---
<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/jpeg" href="/logo.jpeg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <SEO
      title={pageTitle}
      description={desc}
      openGraph={{
        basic: {
          title: pageTitle,
          type: 'website',
          image: ogImgAbsolute,
        },
        optional: {
          description: desc,
          locale: 'id_ID',
          siteName,
        },
        image: ogImageMeta,
      }}
      twitter={{
        card: 'summary_large_image',
        title: pageTitle,
        description: desc,
        image: ogImgAbsolute,
      }}
    />
    <meta name="theme-color" content="#166534" />
    <script is:inline>
      // Default to light regardless of OS preference. Dark only when the user
      // explicitly toggled it (stored as theme=dark).
      (() => {
        try {
          if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark')
          }
        } catch {}
      })()
    </script>
  </head>
  <body class="flex min-h-dvh flex-col">
    <Header settings={settings} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer settings={settings} />
  </body>
</html>
