---
import Logo from './Logo.astro'
import { NAV_LINKS } from '@/lib/constants'
import type { SiteSettings } from '@/lib/types'

interface Props {
  settings: SiteSettings
}
const { settings } = Astro.props
// Local transparent mark — the admin-uploaded logo has a baked-in white box
// that looks wrong on the green footer.
const logoSrc = '/logo.png'
const siteName = settings.siteName ?? 'Majelis Nur Muhammad'
const s = settings.social ?? {}
const year = 2026

const socials = [
  { href: s.youtube, label: 'YouTube' },
  { href: s.tiktok, label: 'TikTok' },
  { href: s.instagram, label: 'Instagram' },
  { href: s.facebook, label: 'Facebook' },
].filter((x) => x.href)
---
<footer class="relative mt-24 bg-primary text-primary-foreground">
  <div class="relative mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-3">
        <Logo src={logoSrc} class="size-12" />
        <span class="font-display text-lg font-bold">{siteName}</span>
      </div>
      <p class="mt-4 max-w-md text-sm leading-relaxed text-primary-foreground/90">
        {settings.footerText}
      </p>
      {
        socials.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {socials.map((soc) => (
              <a
                href={soc.href!}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-full border border-white/20 px-4 py-1.5 text-sm transition-colors hover:bg-white/10"
              >
                {soc.label}
              </a>
            ))}
          </div>
        )
      }
    </div>

    <div>
      <h3 class="font-display text-sm font-semibold tracking-wide text-primary-foreground uppercase">Navigasi</h3>
      <ul class="mt-4 space-y-2 text-sm text-primary-foreground/90">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class="transition-colors hover:underline">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="font-display text-sm font-semibold tracking-wide text-primary-foreground uppercase">Kontak &amp; Donasi</h3>
      <ul class="mt-4 space-y-3 text-sm text-primary-foreground/90">
        <li>
          <span>Wakaf Pembangunan Ponpes Nur Muhammad Banjaran</span>
        </li>
        <li>
          <span>
            No. Rek <strong class="font-semibold text-primary-foreground">BCA</strong> (Bank Central Asia)
            <br />
            <span class="font-mono tracking-wide">1392440024</span>
            <br />
            <span class="text-primary-foreground/75">a.n. Kiagus Akbar Saman</span>
          </span>
        </li>
        <li>
          <a
            href="https://wa.me/6282218776673"
            target="_blank"
            rel="noopener noreferrer"
            class="underline-offset-2 transition-colors hover:underline"
          >
            Informasi &amp; Konfirmasi: 0822-1877-6673
          </a>
        </li>
        {settings.address && <li><span>{settings.address}</span></li>}
        {settings.email && <li><span>{settings.email}</span></li>}
      </ul>
    </div>
  </div>

  <div class="relative border-t border-white/10">
    <p class="mx-auto max-w-6xl px-4 py-5 text-center text-xs text-primary-foreground/85 sm:px-6">
      © {year} {siteName}. Dibuat dengan penuh keberkahan.
    </p>
  </div>
</footer>
