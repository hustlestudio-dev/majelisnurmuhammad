---
import Logo from './Logo.astro'
import StarOrnament from './StarOrnament.astro'
import { NAV_LINKS } from '@/lib/constants'
import { mediaUrl } from '@/lib/payload'
import type { SiteSettings } from '@/lib/types'

interface Props {
  settings: SiteSettings
}
const { settings } = Astro.props
const logoSrc = mediaUrl(settings.logo) ?? '/logo.jpeg'
const siteName = settings.siteName ?? 'Majelis Nur Muhammad'
const s = settings.social ?? {}
const year = 2026

const socials = [
  { href: s.youtube, label: 'YouTube' },
  { href: s.tiktok, label: 'TikTok' },
  { href: s.instagram, label: 'Instagram' },
  { href: s.facebook, label: 'Facebook' },
].filter((x) => x.href)
---
<footer class="relative mt-24 bg-primary text-primary-foreground">
  <div class="pointer-events-none absolute top-0 right-0 opacity-10">
    <StarOrnament variant="solid" class="size-64" />
  </div>
  <div class="relative mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-3">
        <span class="rounded-xl bg-white/10 p-1.5">
          <Logo src={logoSrc} class="size-10" />
        </span>
        <span class="font-display text-lg font-bold">{siteName}</span>
      </div>
      <p class="mt-4 max-w-md text-sm leading-relaxed text-primary-foreground/90">
        {settings.footerText}
      </p>
      {
        socials.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {socials.map((soc) => (
              <a
                href={soc.href!}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-full border border-white/20 px-4 py-1.5 text-sm transition-colors hover:bg-white/10"
              >
                {soc.label}
              </a>
            ))}
          </div>
        )
      }
    </div>

    <div>
      <h3 class="font-display text-sm font-semibold tracking-wide text-gold text-primary-foreground uppercase">Navigasi</h3>
      <ul class="mt-4 space-y-2 text-sm text-primary-foreground/90">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class="transition-colors hover:underline">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="font-display text-sm font-semibold tracking-wide text-gold text-primary-foreground uppercase">Kontak</h3>
      <ul class="mt-4 space-y-2 text-sm text-primary-foreground/90">
        {settings.address && <li>{settings.address}</li>}
        {settings.whatsapp && <li>WA: {settings.whatsapp}</li>}
        {settings.email && <li>{settings.email}</li>}
      </ul>
    </div>
  </div>

  <div class="relative border-t border-white/10">
    <p class="mx-auto max-w-6xl px-4 py-5 text-center text-xs text-primary-foreground/85 sm:px-6">
      © {year} {siteName}. Dibuat dengan penuh keberkahan.
    </p>
  </div>
</footer>
