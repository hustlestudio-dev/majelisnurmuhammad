---
import CategoryBadge from './CategoryBadge.astro'
import StarOrnament from './StarOrnament.astro'
import { mediaUrl } from '@/lib/content'
import { formatDateID } from '@/lib/constants'
import type { Article } from '@/lib/types'

interface Props {
  article: Article
}
const { article } = Astro.props
const cover = mediaUrl(article.coverImage)
const href = `/artikel/${article.slug}`
---
<article
  class="group flex flex-col overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-lg"
>
  <a href={href} class="relative block aspect-[16/10] overflow-hidden">
    {
      cover ? (
        <img
          src={cover}
          alt={article.title}
          class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="flex size-full items-center justify-center bg-gradient-to-br from-primary to-primary-accent">
          <StarOrnament variant="solid" class="size-20 opacity-30" />
        </div>
      )
    }
  </a>
  <div class="flex flex-1 flex-col p-5">
    <CategoryBadge category={article.category} class="mb-3 self-start" />
    <h3 class="font-display text-lg leading-snug font-semibold text-balance">
      <a href={href} class="transition-colors hover:text-primary">{article.title}</a>
    </h3>
    {
      article.excerpt && (
        <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-muted-foreground">
          {article.excerpt}
        </p>
      )
    }
    <div class="mt-4 flex items-center justify-between border-t border-border/60 pt-3 text-xs text-muted-foreground">
      <span>{article.author}</span>
      <span>{formatDateID(article.publishedDate)}</span>
    </div>
  </div>
</article>
