---
import { formatDateID } from '@/lib/constants'
import { richTextToPlain } from '@/lib/richtext'
import type { Announcement } from '@/lib/types'

interface Props {
  announcement: Announcement
}
const { announcement } = Astro.props
const summary = richTextToPlain(announcement.body, 180)
---
<a
  href={`/pengumuman/${announcement.id}`}
  class="group relative block overflow-hidden rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md"
>
  <span
    class:list={[
      'absolute inset-y-0 left-0 w-1.5',
      announcement.pinned ? 'bg-gold' : 'bg-primary/40',
    ]}
    aria-hidden="true"
  />
  <div class="flex flex-wrap items-center gap-2">
    {
      announcement.pinned && (
        <span class="inline-flex items-center gap-1 rounded-full bg-gold px-2.5 py-0.5 text-xs font-semibold text-gold-foreground">
          <svg class="size-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 4h6l-1 7 4 3v2H6v-2l4-3-1-7Zm2 13h2v4l-1 1-1-1v-4Z" />
          </svg>
          Penting
        </span>
      )
    }
    <time class="inline-flex items-center gap-1 text-xs text-muted-foreground">
      <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" />
      </svg>
      {formatDateID(announcement.date)}
    </time>
  </div>
  <h3 class="mt-3 font-display text-lg font-semibold text-balance transition-colors group-hover:text-primary">{announcement.title}</h3>
  {summary && <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{summary}</p>}
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary">
    Selengkapnya
    <svg class="size-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
  </span>
</a>
