---
import StarOrnament from './StarOrnament.astro'
interface Props {
  class?: string
  src?: string | null
}
const { class: className = '', src = '/logo.jpeg' } = Astro.props
const resolved = src || '/logo.jpeg'
---
<span class={`relative inline-flex shrink-0 ${className}`}>
  <img
    src={resolved}
    alt="Logo Majelis Nur Muhammad"
    class="size-full object-contain"
    loading="eager"
    onerror="this.style.display='none';this.nextElementSibling.style.display='block'"
  />
  <StarOrnament variant="solid" class="hidden size-full" />
</span>
