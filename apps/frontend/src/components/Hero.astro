---
import Logo from './Logo.astro'
import Button from './Button.astro'
import { mediaUrl } from '@/lib/content'
import type { SiteSettings, HeroSlide } from '@/lib/types'

interface Props {
  settings: SiteSettings
}
const { settings } = Astro.props
const logoSrc = mediaUrl(settings.logo) ?? '/logo.jpeg'
const siteName = settings.siteName ?? 'Majelis Nur Muhammad'
const tagline = settings.tagline ?? 'Pondok Pesantren Nur Muhammad Al-Hasany Banjaran'

const slides: HeroSlide[] =
  settings.heroSlides && settings.heroSlides.length > 0
    ? settings.heroSlides
    : [
        {
          image: null,
          heading: siteName,
          subheading: tagline,
          arabic: settings.heroVerse?.arabic ?? 'نُورُ مُحَمَّد',
          ctaLabel: 'Jadwal Pengajian',
          ctaHref: '/jadwal',
        },
      ]
const multiple = slides.length > 1

// Resolve a public media URL for a hero image (R2/CDN in prod, internal proxy in dev).
const resolve = Astro.locals.emdash?.getPublicMediaUrl
const bgUrl = (img: HeroSlide['image']): string | null => {
  if (!img) return null
  if (img.storageKey) return resolve ? resolve(img.storageKey) : `/_emdash/api/media/file/${img.storageKey}`
  if (img.id) return `/_emdash/api/media/file/${img.id}`
  return null
}

const view = slides.map((s) => ({
  ...s,
  bg: bgUrl(s.image),
  ctaLabel: s.ctaLabel || 'Jadwal Pengajian',
  ctaHref: s.ctaHref || '/jadwal',
}))
---
<section
  class="relative isolate overflow-hidden"
  data-hero
  aria-roledescription="carousel"
  aria-label="Sorotan Majelis"
>
  <div class="relative min-h-[88vh] w-full">
    {
      view.map((slide, i) => (
        <div
          class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-700 ease-out data-[active]:opacity-100 data-[active]:z-10"
          data-slide
          data-active={i === 0 ? '' : undefined}
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} dari ${slides.length}`}
          aria-hidden={i === 0 ? 'false' : 'true'}
        >
          {/* Background */}
          {slide.bg ? (
            <img
              src={slide.bg}
              alt={slide.image?.alt ?? ''}
              class="absolute inset-0 -z-10 size-full object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
              decoding="async"
            />
          ) : (
            <div class="absolute inset-0 -z-10 bg-[#0c0f0d]">
              <div
                class="absolute inset-0"
                style="background: radial-gradient(120% 90% at 50% 0%, #19362a 0%, #11231b 45%, #0a0f0c 100%)"
              />
            </div>
          )}

          {/* Readability overlay (neutral, not green) */}
          <div
            class="absolute inset-0"
            aria-hidden="true"
            style="background: linear-gradient(to bottom, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.35) 40%, rgba(0,0,0,0.78) 100%)"
          />

          {/* Content */}
          <div class="relative mx-auto flex max-w-3xl flex-col items-center px-4 py-24 text-center sm:px-6">
            {!slide.bg && (
              <div class="hero-rise mb-8" style="--d:0ms">
                <span class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/5 p-3 shadow-2xl shadow-black/40 backdrop-blur-sm">
                  <Logo src={logoSrc} class="size-24 drop-shadow-lg sm:size-28" />
                </span>
              </div>
            )}

            <span class="hero-rise inline-flex items-center gap-2 rounded-full border border-gold/40 bg-black/20 px-4 py-1.5 text-xs font-semibold tracking-[0.2em] text-gold uppercase shadow-sm backdrop-blur" style="--d:80ms">
              <span class="size-1.5 rounded-full bg-gold" />
              Assalamu'alaikum Warahmatullah
            </span>

            {slide.arabic && (
              <p
                dir="rtl"
                lang="ar"
                class="hero-rise font-arabic mt-7 text-4xl leading-loose text-gold [text-shadow:0_2px_20px_rgba(0,0,0,0.6)] sm:text-5xl"
                style="--d:160ms"
              >
                {slide.arabic}
              </p>
            )}

            <h1 class="hero-rise mt-4 font-display text-4xl font-extrabold tracking-tight text-balance text-white [text-shadow:0_2px_16px_rgba(0,0,0,0.55)] sm:text-6xl" style="--d:240ms">
              {slide.heading}
            </h1>

            <div class="hero-rise mt-6 flex items-center gap-3" style="--d:300ms" aria-hidden="true">
              <span class="h-px w-12 bg-gradient-to-r from-transparent to-gold/70 sm:w-20" />
              <span class="size-1.5 rotate-45 bg-gold" />
              <span class="h-px w-12 bg-gradient-to-l from-transparent to-gold/70 sm:w-20" />
            </div>

            {slide.subheading && (
              <p class="hero-rise mt-6 max-w-2xl text-base text-pretty text-white/85 [text-shadow:0_1px_10px_rgba(0,0,0,0.7)] sm:text-lg" style="--d:360ms">
                {slide.subheading}
              </p>
            )}

            <div class="hero-rise mt-10 flex flex-wrap items-center justify-center gap-3" style="--d:440ms">
              <Button href={slide.ctaHref} variant="gold" size="lg">
                {slide.ctaLabel}
              </Button>
              <Button
                href="/tentang"
                size="lg"
                class="border border-white/30 bg-white/10 text-white hover:bg-white/20"
              >
                Tentang Kami
              </Button>
            </div>
          </div>
        </div>
      ))
    }

    {
      multiple && (
        <>
          <button
            type="button"
            data-hero-prev
            aria-label="Slide sebelumnya"
            class="absolute top-1/2 left-3 z-20 flex size-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/30 bg-black/30 text-white backdrop-blur transition hover:bg-black/50 sm:left-6"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button
            type="button"
            data-hero-next
            aria-label="Slide berikutnya"
            class="absolute top-1/2 right-3 z-20 flex size-11 -translate-y-1/2 items-center justify-center rounded-full border border-white/30 bg-black/30 text-white backdrop-blur transition hover:bg-black/50 sm:right-6"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>

          <div class="absolute bottom-6 left-1/2 z-20 flex -translate-x-1/2 gap-2.5">
            {view.map((_, i) => (
              <button
                type="button"
                data-hero-dot
                aria-label={`Ke slide ${i + 1}`}
                class="size-2.5 rounded-full bg-white/40 transition-all data-[active]:w-7 data-[active]:bg-gold"
                data-active={i === 0 ? '' : undefined}
              />
            ))}
          </div>

          <button
            type="button"
            data-hero-toggle
            aria-label="Jeda korsel"
            aria-pressed="true"
            class="absolute right-3 bottom-5 z-20 flex size-11 items-center justify-center rounded-full border border-white/30 bg-black/30 text-white backdrop-blur transition hover:bg-black/50 sm:right-6"
          >
            <svg data-hero-icon-pause class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>
            <svg data-hero-icon-play class="hidden size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5.14v13.72a1 1 0 0 0 1.54.84l10.3-6.86a1 1 0 0 0 0-1.68L9.54 4.3A1 1 0 0 0 8 5.14Z"/></svg>
          </button>
        </>
      )
    }
  </div>
</section>

<style>
  @keyframes heroRise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .hero-rise {
    opacity: 0;
    animation: heroRise 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d, 0ms);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-rise {
      opacity: 1;
      animation: none;
    }
  }
</style>

{
  multiple && (
    <script is:inline>
      ;(() => {
        const root = document.querySelector('[data-hero]')
        if (!root) return
        const slides = [...root.querySelectorAll('[data-slide]')]
        const dots = [...root.querySelectorAll('[data-hero-dot]')]
        let i = 0
        let timer
        const show = (n) => {
          i = (n + slides.length) % slides.length
          slides.forEach((s, k) => {
            if (k === i) {
              s.setAttribute('data-active', '')
              s.setAttribute('aria-hidden', 'false')
            } else {
              s.removeAttribute('data-active')
              s.setAttribute('aria-hidden', 'true')
            }
          })
          dots.forEach((d, k) =>
            k === i ? d.setAttribute('data-active', '') : d.removeAttribute('data-active'),
          )
        }
        const next = () => show(i + 1)
        const prev = () => show(i - 1)
        const reduce = matchMedia('(prefers-reduced-motion: reduce)')
        const toggle = root.querySelector('[data-hero-toggle]')
        const iconPause = root.querySelector('[data-hero-icon-pause]')
        const iconPlay = root.querySelector('[data-hero-icon-play]')
        let playing = false
        const stop = () => {
          if (timer) clearInterval(timer)
          timer = null
        }
        const reflect = () => {
          if (!toggle) return
          toggle.setAttribute('aria-pressed', String(playing))
          toggle.setAttribute('aria-label', playing ? 'Jeda korsel' : 'Putar korsel')
          iconPause?.classList.toggle('hidden', !playing)
          iconPlay?.classList.toggle('hidden', playing)
        }
        const run = () => {
          stop()
          timer = setInterval(next, 6000)
        }
        const play = () => {
          playing = true
          run()
          reflect()
        }
        const pause = () => {
          playing = false
          stop()
          reflect()
        }
        root.querySelector('[data-hero-next]')?.addEventListener('click', () => {
          next()
          if (playing) run()
        })
        root.querySelector('[data-hero-prev]')?.addEventListener('click', () => {
          prev()
          if (playing) run()
        })
        dots.forEach((d, k) =>
          d.addEventListener('click', () => {
            show(k)
            if (playing) run()
          }),
        )
        toggle?.addEventListener('click', () => (playing ? pause() : play()))
        root.addEventListener('mouseenter', () => playing && stop())
        root.addEventListener('mouseleave', () => playing && run())
        if (reduce.matches) pause()
        else play()
      })()
    </script>
  )
}
