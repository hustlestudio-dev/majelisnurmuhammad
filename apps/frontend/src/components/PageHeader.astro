---
import StarOrnament from './StarOrnament.astro'
import Divider from './Divider.astro'
interface Props {
  title: string
  subtitle?: string
}
const { title, subtitle } = Astro.props
---
<section class="islamic-grid relative border-b border-border/60">
  <StarOrnament class="pointer-events-none absolute top-0 right-0 size-40 opacity-[0.07]" />
  <StarOrnament class="pointer-events-none absolute bottom-0 left-0 size-44 opacity-[0.07]" />
  <div class="relative mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-20">
    <h1 class="font-display text-4xl font-extrabold text-balance sm:text-5xl">
      <span class="text-gradient-emerald">{title}</span>
    </h1>
    {subtitle && <p class="mx-auto mt-4 max-w-xl text-pretty text-muted-foreground">{subtitle}</p>}
    <Divider class="mt-7" />
  </div>
</section>
