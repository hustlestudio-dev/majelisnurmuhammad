# Payload secret (generate: openssl rand -hex 32)
PAYLOAD_SECRET=

# Turso (libSQL) database
# Local dev can use a file: URL. Prod = Turso libsql:// URL + auth token.
#   turso db create nurmuhammad
#   turso db show nurmuhammad --url
#   turso db tokens create nurmuhammad
DATABASE_URI=file:./payload.db
DATABASE_AUTH_TOKEN=

# Cloudflare R2 (via S3 API) for media uploads
S3_BUCKET=nurmuhammad-media
S3_ENDPOINT=https://cd4a1d42e74f9b8d4c6ee9523e00179c.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Public URLs (set on Netlify)
# Payload's own deployed URL:
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Astro frontend URL (for CORS/CSRF):
FRONTEND_URL=http://localhost:4321

# Optional: token to protect the /seed route (defaults to PAYLOAD_SECRET)
SEED_TOKEN=
